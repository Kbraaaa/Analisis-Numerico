# PROGRAMA PRINCIPAL
# --------------------------

print("=== Método de Gauss-Seidel ===")

n = int(input("Ingrese el número de ecuaciones: "))

A = []
print("Ingrese la matriz de coeficientes:")
for i in range(n):
    fila = list(map(float, input(f"Fila {i+1}: ").split()))
    A.append(fila)

b = list(map(float, input("Ingrese el vector b: ").split()))

print("Ingrese valores iniciales:")
x0 = list(map(float, input("Ejemplo: 0 0 0 : ").split()))

max_iter = int(input("Ingrese número máximo de iteraciones: "))
tol = float(input("Ingrese tolerancia: "))

gauss_seidel(A, b, x0, max_iter, tol)



