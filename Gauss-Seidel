def gauss_seidel(A, b, x0, max_iter, tol):
    n = len(A)
    x = x0.copy()

    print("\nIteración\tSolución\t\tError")

    for k in range(max_iter):
        x_nuevo = x.copy()

        for i in range(n):
            suma = 0
            for j in range(n):
                if j != i:
                    suma += A[i][j] * x_nuevo[j]  # usa valores actualizados

            x_nuevo[i] = (b[i] - suma) / A[i][i]

        # calcular error
        error = max(abs(x_nuevo[i] - x[i]) for i in range(n))

        print(f"{k}\t\t{x_nuevo}\t{error:.6f}")

        if error < tol:
            print("\nSolución aproximada:", x_nuevo)
            return x_nuevo

        x = x_nuevo

    print("\nSe alcanzó el máximo de iteraciones")
    print("Última aproximación:", x)
    return x


